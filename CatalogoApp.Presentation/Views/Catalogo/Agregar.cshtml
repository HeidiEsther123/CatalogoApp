@model CatalogoApp.Domain.Models.Item

<div class="text-center mb-4">
    <h1>Agregar Videojuego</h1>
</div>

<form asp-action="Agregar" method="post" class="card-gamer p-4 mx-auto" style="max-width:600px;">
    <div class="mb-3">
        <label asp-for="Titulo" class="form-label-gamer">Título</label>
        <input asp-for="Titulo" class="form-control-gamer form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Genero" class="form-label-gamer">Género</label>
        <input asp-for="Genero" class="form-control-gamer form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Consola" class="form-label-gamer">Consola</label>
        <input asp-for="Consola" class="form-control-gamer form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Ano" class="form-label-gamer">Año</label>
        <input asp-for="Ano" type="number" class="form-control-gamer form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Descripcion" class="form-label-gamer">Descripción</label>
        <textarea asp-for="Descripcion" class="form-control-gamer form-control" rows="3"></textarea>
    </div>

    <div class="text-center mt-4">
        <button type="submit" class="btn-gamer">Guardar</button>
        <a asp-action="Index" class="btn-gamer ms-2">← Cancelar</a>
    </div>
</form>