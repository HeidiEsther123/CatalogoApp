@model CatalogoApp.Domain.Models.Item

<div class="card-gamer shadow-sm p-4 mx-auto mt-4" style="max-width:600px;">
    <h2 class="mb-4 text-center">@Model.Titulo</h2>

    <p><strong>Género:</strong> <span class="text-purple-light">@Model.Genero</span></p>
    <p><strong>Consola:</strong> <span class="text-purple-light">@Model.Consola</span></p>
    <p><strong>Año:</strong> <span class="text-purple-light">@Model.Ano</span></p>
    
    <div class="mt-4 mb-4">
        <h5 class="form-label-gamer">Descripción:</h5>
        <p>@Model.Descripcion</p>
    </div>

    <div class="text-center mt-4">
        <a asp-action="Index" class="btn-gamer">
            ← Volver al catálogo
        </a>
    </div>
</div>
