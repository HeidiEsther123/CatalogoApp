@{
    ViewData["Title"] = "Login Gamer";
}

<div class="text-center mb-4">
    <h1 class="display-4">Login <span class="text-purple-light">Gamer</span></h1>
    <p class="text-muted"> Enter your credentials</p>
</div>

<div class="card-gamer p-4 mx-auto shadow" style="max-width: 400px; border-top: 3px solid #ffcc00;">
    <form asp-action="Login" method="post">

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger bg-danger text-white border-0 mb-3 small">
                @ViewBag.Error
            </div>
        }

        @if (TempData["MensajeExito"] != null)
        {
            <div class="alert alert-success bg-success text-white border-0 mb-3 small">
               @TempData["MensajeExito"]
            </div>
        }

        <div class="mb-3">
            <label class="form-label-gamer">Nickname</label>
            <input type="text" name="username" class="form-control form-control-gamer" required placeholder="Your User" />
        </div>

        <div class="mb-4">
            <label class="form-label-gamer">Password</label>
            <input type="password" name="password" class="form-control form-control-gamer" required placeholder="#•#•#•#•" />
        </div>

        <button type="submit" class="btn-gamer w-100 mb-3">
            sign in
        </button>

        <div class="text-center">
            <p class="small mb-0">
                Don’t have an account?  <br />
                <a asp-action="Register" class="text-purple-light fw-bold">Sign up here</a>
            </p>
        </div>
    </form>
</div>
